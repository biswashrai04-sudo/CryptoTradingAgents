    "debug.onTaskErrors": "show",
    "python.terminal.activateEnvInCurrentTerminal": true,
    "python.terminal.launchArgs": [],
    "python.debugger.autoReload": true,
    "python.debugger.autoAttachChildProcesses": true,
    "intellifix.enableInlineErrors": true,
    "intellifix.languages": ["python"]
}
