{
    "python.defaultInterpreterPath": "C:\\Users\\WINDOWS 11 PRO\\AppData\\Local\\Programs\\Python\\Python312\\python.exe",
    "python.analysis.extraPaths": [
        "C:\\Users\\WINDOWS 11 PRO\\AppData\\Local\\Programs\\Python\\Python312\\Lib\\site-packages"
    ],
    "[python]": {
        "editor.defaultFormatter": "charliermarsh.ruff",
        "editor.formatOnSave": true,
        "editor.codeActionsOnSave": {
            "source.fixAll.ruff": "explicit",
            "source.organizeImports.ruff": "explicit"
        }
    },
    "ruff.lint.run": "onSave",
    "ruff.format.args": ["--config", "pyproject.toml"],
    "debug.autoReload": true,
